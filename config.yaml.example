gitlab:
  url: https://gitlab.com
  token: your-gitlab-token
slack:
  webhook_url: https://hooks.slack.com/services/your-slack-webhook-url
projects:
  - id: 123
  - id: 456
groups:
  - id: 1
  - id: 2
cron_schedule: "0 7,13 * * 1-5"
authors:
  - username: "janedoe"
  - username: "johndoe"
  - id: 918

# Smart notification (optional — omit for legacy behavior)
notification:
  mode: "webhook"                # "webhook" (channel mentions) or "dm" (bot DM)
  webhook:
    url: https://hooks.slack.com/services/your-webhook-url
  # bot:                         # Uncomment for DM mode
  #   token: "xoxb-your-bot-token"

# GitLab-to-Slack user mapping (required for smart notification)
user_mapping:
  - gitlab_username: "janedoe"
    slack_id: "U01234ABCD"
  - gitlab_username: "johndoe"
    slack_id: "U05678EFGH"

# Notification state file for deduplication (optional)
state:
  path: "/data/notification_state.json"

# Scheduled summary (optional — enable periodic full MR status report)
summary:
  schedule: "0 9 * * 1-5"          # Weekdays 9 AM
  # webhook_url: "..."             # Optional: separate channel (falls back to notification.webhook.url)
  # stale_days: 7                  # Optional: default 7
